@page
@model GolfClubDb.Pages.Members.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>

<div>
<!-- Gender Filter -->
    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-md-6">
        <select asp-for="GenderFilter" asp-items="Html.GetEnumSelectList<GolfClubDb.Models.Gender>()" class="form-select">
            <option value = "">All</option>
        </select>
        <input type="submit" value="Filter by Gender" class="btn btn-primary" />
    </div>

        <div class="col-md-6">
            <select asp-for="HandicapFilter" class="form-select">
                <option value="">All</option>
                <option value="Below 10">Below 10</option>
                <option value="Between 11 and 20">Between 11 and 20</option>
                <option value="Above 20">Above 20</option>
            </select>
            <input type="submit" value="Filter by Handicap" class="btn btn-secondary" />
    </div>
</form>

<!-- Handicap Filter -->
<form method="get">

</form>
</div>

<!-- Sort Buttons-->
<a asp-page="./Index" asp-route-sortOrder="name_asc"> Sort Name Asc</a> |
<a asp-page="./Index" asp-route-sortOrder="name_desc"> Sort Name Desc</a> |
<a asp-page="./Index" asp-route-sortOrder="handicap_asc"> Sort Handicap Asc</a> |
<a asp-page="./Index" asp-route-sortOrder="handicap_desc"> Sort Handicap Desc</a> 


<table class="table">
    <thead>
        <tr>
            <th>
                Member Number
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Member[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Member[0].Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Member[0].Gender)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Member[0].Handicap)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Member) {
        <tr>
            <td>
                @item.Id
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Gender)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Handicap)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
