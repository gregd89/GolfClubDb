@page
@model GolfClubDb.Pages.Members.DetailsModel

@{
    ViewData["Title"] = "Member Details";
}

<h1>Member Details</h1>

<div class="container">
    <div class="row justify-content-center">

        <!-- Member Card -->
        <div class="card shadow mt-3">
            <div class="card-body">
                <h4>Member</h4>
                <hr />
                <dl class="row">
                    <dt class="col-sm-2">
                        Member Number
                    </dt>
                    <dd class="col-sm-10">
                        @Model.Member.Id
                    </dd>
                    <dt class="col-sm-2">
                        @Html.DisplayNameFor(model => model.Member.Name)
                    </dt>
                    <dd class="col-sm-10">
                        @Html.DisplayFor(model => model.Member.Name)
                    </dd>
                    <dt class="col-sm-2">
                        @Html.DisplayNameFor(model => model.Member.Email)
                    </dt>
                    <dd class="col-sm-10">
                        @Html.DisplayFor(model => model.Member.Email)
                    </dd>
                    <dt class="col-sm-2">
                        @Html.DisplayNameFor(model => model.Member.Gender)
                    </dt>
                    <dd class="col-sm-10">
                        @Html.DisplayFor(model => model.Member.Gender)
                    </dd>
                    <dt class="col-sm-2">
                        @Html.DisplayNameFor(model => model.Member.Handicap)
                    </dt>
                    <dd class="col-sm-10">
                        @Html.DisplayFor(model => model.Member.Handicap)
                    </dd>
                </dl>

                <!-- Member Buttons -->
                <div class="row g-2 mb-3">
                    <div class="col-12 col-md-6 d-grid">
                        <a asp-page="./Edit" asp-route-id="@Model.Member.Id" class="btn btn-primary">Edit</a>
                    </div>
                    <div class="col-12 col-md-6 d-grid">
                        <a asp-page="./Index" class="btn btn-info">Back to List</a>
                    </div>
                    <div class="col-12 d-grid">
                        <a asp-page="./Delete" asp-route-id="@Model.Member.Id" class="btn btn-outline-danger">Delete</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Members Bookings Card -->
        <div class="card shadow mt-3">
            <div class="card-body">
                <h4>Members Bookings</h4>
                <hr />
                <table class="table table-hover">
                    <thead>
                        <tr class="table-secondary">
                            <th scope="col">
                                Date
                            </th>
                            <th scope="col">
                                Time
                            </th>
                            <th scope="col">
                                Players
                            </th>
                            <th scope="col">
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.RelatedBookings)
                        {
                            <tr class="table-light">
                                <td>
                                    @item.TeeDate
                                </td>
                                <td>
                                    @item.TeeTime
                                </td>
                                <td>
                                    @item.Player1Member?.Name <br />
                                    @item.Player2Member?.Name <br />
                                    @item.Player3Member?.Name <br />
                                    @item.Player4Member?.Name
                                </td>
                                <td>
                                    <a asp-page="/Bookings/Edit" asp-route-id="@item.Id" class="btn btn-outline-warning">Edit</a>
                                    <a asp-page="/Bookings/Details" asp-route-id="@item.Id" class="btn btn-outline-info">Details</a>
                                    <a asp-page="/Bookings/Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>


    </div>
</div> <!-- Container -->