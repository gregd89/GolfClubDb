@page
@model GolfClubDb.Pages.Members.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Member</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Member Number
        </dt>
        <dd class="col-sm-10">
            @Model.Member.Id
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Member.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Member.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Member.Email)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Member.Email)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Member.Gender)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Member.Gender)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Member.Handicap)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Member.Handicap)
        </dd>
    </dl>
</div>

<div>
    <h5>Bookings</h5>
    <table class="table">
        <thead>
            <tr>
                <th>
                Date
                </th>
                <th>
                Time
                </th>
                <th>
                Players
                </th>
                <th>
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.RelatedBookings)
            {
                <tr>
                    <td>
                        @item.TeeDate
                    </td>
                    <td>
                        @item.TeeTime
                    </td>
                    <td>
                        @item.Player1Member?.Name <br />
                        @item.Player2Member?.Name <br />
                        @item.Player3Member?.Name <br />
                        @item.Player4Member?.Name
                    </td>
                    <td>
                        <a asp-page="/Bookings/Edit" asp-route-id="@item.Id">Edit</a> |
                        <a asp-page="/Bookings/Details" asp-route-id="@item.Id">Details</a> |
                        <a asp-page="/Bookings/Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


<div>
    <a asp-page="./Edit" asp-route-id="@Model.Member.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
