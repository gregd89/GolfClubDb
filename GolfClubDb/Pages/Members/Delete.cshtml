@page
@model GolfClubDb.Pages.Members.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete Member</h1>

<div>
    <h4>Member</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Member.MembershipNumber)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Member.MembershipNumber)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Member.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Member.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Member.Email)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Member.Email)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Member.Gender)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Member.Gender)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Member.Handicap)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Member.Handicap)
        </dd>
    </dl>

    <div class="alert alert-dismissible alert-warning">
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        <h4 class="alert-heading">Warning!</h4>
        <p class="mb-3">Are you sure you want to delete this?</p>
        <form method="post">
            <input type="hidden" asp-for="Member.Id" />
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-page="./Index" class="btn btn-info">Back to List</a>
        </form>
    </div>


</div>
