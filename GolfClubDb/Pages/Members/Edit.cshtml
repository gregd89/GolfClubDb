@page
@model GolfClubDb.Pages.Members.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit Member</h1>

<div class="container">
    <div class="row justify-content-center">

        <div class="card shadow mt-3">
            <div class="card-body">
                <h4>Member</h4>
                <hr />
                <div class="row">
                    <div class="col-md-4">
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <input type="hidden" asp-for="Member.Id" />

                            <div class="form-group">
                                <label asp-for="Member.Name" class="control-label"></label>
                                <input asp-for="Member.Name" class="form-control" />
                                <span asp-validation-for="Member.Name" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Member.Email" class="control-label"></label>
                                <input asp-for="Member.Email" class="form-control" />
                                <span asp-validation-for="Member.Email" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Member.Gender" class="control-label"></label>
                                <select asp-for="Member.Gender" class="form-control" asp-items="Model.GenderSelectList">
                                    <option value=""> Select a Gender</option>
                                </select>
                                <span asp-validation-for="Member.Gender" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Member.Handicap" class="control-label"></label>
                                <input asp-for="Member.Handicap" class="form-control" />
                                <span asp-validation-for="Member.Handicap" class="text-danger"></span>
                            </div>

                        </form>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="row g-2 mt-3">
                    <div class="col-12 col-md-6 d-grid">
                        <input type="submit" value="Save" class="btn btn-primary" />
                    </div>
                    <div class="col-12 col-md-6 d-grid">
                        <a asp-page="./Index" class="btn btn-info">Back to List</a>
                    </div>
                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
