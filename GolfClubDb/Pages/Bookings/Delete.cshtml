@page
@model GolfClubDb.Pages.Bookings.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete Booking</h1>

<div class="container">
    <div class="row justify-content-center">

        <div class="alert alert-dismissible alert-warning mt-3">
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            <h4 class="alert-heading">Warning!</h4>
            <p class="mb-3">Are you sure you want to delete this?</p>
            <form method="post">
                <input type="hidden" asp-for="Bookings.Id" />
                <input type="submit" value="Yes, Delete it" class="btn btn-danger" />
                <a asp-page="./Index" class="btn btn-info">Back to List</a>
            </form>
        </div>

        <!-- Booking Card -->
        <div class="card shadow mt-3">
            <div class="card-body">
                <h4>Booking Details</h4>
                <hr />

                <dl class="row">
                    <dt class="col-sm-2">
                        @Html.DisplayNameFor(model => model.Bookings.TeeDate)
                    </dt>
                    <dd class="col-sm-10">
                        @Html.DisplayFor(model => model.Bookings.TeeDate)
                    </dd>
                    <dt class="col-sm-2">
                        @Html.DisplayNameFor(model => model.Bookings.TeeTime)
                    </dt>
                    <dd class="col-sm-10">
                        @Html.DisplayFor(model => model.Bookings.TeeTime)
                    </dd>
                </dl>
                </div>
                </div>


                <!-- Players This Booking Card -->
                <div class="card shadow mt-3">
                    <div class="card-body">
                        <h4>Players This Booking</h4>
                        <hr />
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr class="table-secondary">
                                    <th scope="col">#</th>
                                    <th scope="col">Player</th>
                                    <th scope="col">Handicap</th>
                                    <th scope="col"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="table-light">
                                    <td>1</td>
                                    <td>@Model.Bookings.Player1Member?.Name</td>
                                    <td>@Model.Bookings.Player1Member?.Handicap</td>
                                    <td>
                                        @if (Model.Bookings.Player1Member != null)
                                        {
                                            <a class="btn btn-outline-info btn-sm"
                                               asp-page="/Members/Details"
                                               asp-route-id="@Model.Bookings.Player1Member.Id">View Member</a>
                                        }
                                    </td>
                                </tr>

                                <tr class="table-light">
                                    <td>2</td>
                                    <td>@Model.Bookings.Player2Member?.Name</td>
                                    <td>@Model.Bookings.Player2Member?.Handicap</td>
                                    <td>
                                        @if (Model.Bookings.Player2Member != null)
                                        {
                                            <a class="btn btn-outline-info btn-sm"
                                               asp-page="/Members/Details"
                                               asp-route-id="@Model.Bookings.Player2Member.Id">View Member</a>
                                        }
                                    </td>
                                </tr>

                                <tr class="table-light">
                                    <td>3</td>
                                    <td>@Model.Bookings.Player3Member?.Name</td>
                                    <td>@Model.Bookings.Player3Member?.Handicap</td>
                                    <td>
                                        @if (Model.Bookings.Player3Member != null)
                                        {
                                            <a class="btn btn-outline-info btn-sm"
                                               asp-page="/Members/Details"
                                               asp-route-id="@Model.Bookings.Player3Member.Id">View Member</a>
                                        }
                                    </td>
                                </tr>

                                <tr class="table-light">
                                    <td>4</td>
                                    <td>@Model.Bookings.Player4Member?.Name</td>
                                    <td>@Model.Bookings.Player4Member?.Handicap</td>
                                    <td>
                                        @if (Model.Bookings.Player4Member != null)
                                        {
                                            <a class="btn btn-outline-info btn-sm"
                                               asp-page="/Members/Details"
                                               asp-route-id="@Model.Bookings.Player4Member.Id">View Member</a>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>



</div>
</div>

