@page
@model GolfClubDb.Pages.Bookings.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Bookings[0].Member)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Bookings[0].TeeDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Bookings[0].TeeTime)
            </th>
