                @Html.DisplayNameFor(model => model.Bookings[0].Player1Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Bookings[0].Player1Handicap)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Bookings[0].Player2Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Bookings[0].Player2Handicap)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Bookings[0].Player3Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Bookings[0].Player3Handicap)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Bookings[0].Player4Name)
            </th>
