@page
@model GolfClubDb.Pages.Bookings.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create a Booking</h1>

<div class="container">
    <div class="row justify-content-center">

        <div class="card shadow mt-3">
            <div class="card-body">
                <h4>Booking</h4>
                <hr />
                <div class="row">
                    <div class="col-lg-6">
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <div class="form-group">
                                <label asp-for="Bookings.TeeDate" class="control-label"></label>
                                <input asp-for="Bookings.TeeDate" class="form-control" type="date" />
                                <span asp-validation-for="Bookings.TeeDate" class="text-danger" value="@DateTime.Today.ToString("yyyy-MM-dd")"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Bookings.TeeTime" class="control-label"></label>
                                <select asp-for="Bookings.TeeTime" class="form-control" asp-items="Model.TimeOptions">
                                    <option value="">Select a time</option>
                                </select>
                                <span asp-validation-for="Bookings.TeeTime" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Bookings.Player1MemberId" class="control-label">Player 1</label>
                                <select asp-for="Bookings.Player1MemberId" class="form-control" asp-items="ViewBag.Members">
                                    <option value=""> Select a Member</option>
                                </select>
                                <span asp-validation-for="Bookings.Player1MemberId" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Bookings.Player2MemberId" class="control-label">Player  2</label>
                                <select asp-for="Bookings.Player2MemberId" class="form-control" asp-items="ViewBag.Members">
                                    <option value=""> Select a Member</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label asp-for="Bookings.Player3MemberId" class="control-label">Player 3</label>
                                <select asp-for="Bookings.Player3MemberId" class="form-control" asp-items="ViewBag.Members">
                                    <option value=""> Select a Member</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label asp-for="Bookings.Player4MemberId" class="control-label">Player 4</label>
                                <select asp-for="Bookings.Player4MemberId" class="form-control" asp-items="ViewBag.Members">
                                    <option value=""> Select a Member</option>
                                </select>
                            </div>

                            <!-- Buttons -->
                            <div class="row g-2 mt-3">
                                <div class="col-12 col-md-6 d-grid">
                                    <input type="submit" value="Create" class="btn btn-primary" />
                                </div>
                                <div class="col-12 col-md-6 d-grid">
                                    <a asp-page="Index" class="btn btn-info">Back to List</a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
